# ── Secrets — NEVER allow into the image ──────────────────────────────
.env
.env.*
*.pem
*.key

# ── Python build artifacts ────────────────────────────────────────────
__pycache__
*.pyc
*.pyo
*.pyd
.venv
*.egg-info

# ── Testing artifacts ─────────────────────────────────────────────────
tests
.pytest_cache
.coverage
htmlcov

# ── Local data — built per-user at runtime, not baked into image ──────
data
faiss_index
faiss_indexes
*.pdf
*.pkl

# ── Git and IDE noise ─────────────────────────────────────────────────
.git
.gitignore
.vscode
.idea

# ── Docker metafiles ──────────────────────────────────────────────────
.dockerignore
Dockerfile

# ── Project housekeeping ──────────────────────────────────────────────
README.md
*.md
test_run.py
env.yaml